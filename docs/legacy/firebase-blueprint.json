{
  "entities": {
    "Track": {
      "title": "Track",
      "description": "A music track in the portfolio.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the track."
        },
        "title": {
          "type": "string",
          "description": "The title of the track."
        },
        "artist": {
          "type": "string",
          "description": "The artist of the track."
        },
        "coverImage": {
          "type": "string",
          "format": "uri",
          "description": "URL to the cover image (Firebase Storage URL)."
        },
        "audioUrl": {
          "type": "string",
          "format": "uri",
          "description": "URL to the audio file (Firebase Storage URL)."
        },
        "description": {
          "type": "string",
          "description": "A short description of the track."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Genre or mood tags."
        },
        "createdAt": {
          "type": "string",
          "description": "Creation date string."
        },
        "order": {
          "type": "number",
          "description": "Order for displaying tracks."
        }
      },
      "required": ["title", "artist", "coverImage", "audioUrl"]
    }
  },
  "firestore": {
    "/tracks/{trackId}": {
      "schema": {
        "$ref": "#/entities/Track"
      },
      "description": "Collection of music tracks."
    }
  }
}
