rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "okumura@physical-balance-lab.net";
    }

    match /tracks/{trackId} {
      // Anyone can read tracks (public portfolio)
      allow read: if true;
      // Only admin can create/update/delete tracks
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
