# コピーして .env.local に保存

# --- Google Drive API ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_DRIVE_FOLDER_ID=

# リフレッシュトークン暗号化（8文字以上）
TOKEN_ENCRYPTION_KEY=

# --- 管理者 API（/api/admin/upload）認証: どちらか（または両方）---
# OAuth 連携成功時に HttpOnly Cookie を付与するための署名鍵（16文字以上推奨）
SESSION_SECRET=
# ヘッダー X-Admin-Secret と一致させるとアップロード可（Cookie が無い環境向け）
ADMIN_SECRET=

# --- フロント（開発時・任意）---
# 上と同じ ADMIN_SECRET を入れると管理画面で毎回入力しなくてよい（本番ではビルドに秘密を埋め込まないこと）
# VITE_ADMIN_SECRET=
# 本番で API を別オリジンに出す場合のみ（末尾スラッシュなし）。未設定なら相対パス /api（Vite プロキシ or 同一オリジン）
# VITE_API_BASE_URL=https://api.example.com

# --- 任意 ---
# API_PORT=8787
# GOOGLE_DRIVE_CATALOG_FILE_ID=
# CATALOG_ID_PATH=data/catalog-file-id.txt
