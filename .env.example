# コピーして .env または .env.local に保存（API は両方を読み、.env.local が優先）

# --- Vercel Blob + Neon DB ---
DATABASE_URL=
BLOB_READ_WRITE_TOKEN=

# --- 管理者 API（/api/admin/blob-upload, /api/admin/upload/complete）認証: どちらか（または両方）---
# HttpOnly Cookie 用の署名鍵（16文字以上推奨）。/api/admin/session で Cookie を発行できます。
SESSION_SECRET=
# ヘッダー X-Admin-Secret と一致させるとアップロード可（ローカルでは推奨）
ADMIN_SECRET=

# --- フロント（開発時・任意）---
# 上と同じ ADMIN_SECRET を入れると管理画面で毎回入力しなくてよい（本番ではビルドに秘密を埋め込まないこと）
# VITE_ADMIN_SECRET=
# 本番で API を別オリジンに出す場合のみ（末尾スラッシュなし）。未設定なら相対パス /api（Vite プロキシ or 同一オリジン）
# VITE_API_BASE_URL=https://api.example.com

# --- 任意 ---
# API_PORT=8787
