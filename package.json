{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server:dev": "tsx watch server/index.ts",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run server:dev\" \"wait-on tcp:127.0.0.1:8787 && npm run dev\"",
    "start": "tsx server/index.ts",
    "build": "vite build && npm run build:api",
    "build:api": "esbuild api/_handler.ts --bundle --platform=node --format=esm --outfile=api/index.mjs --packages=external",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@upstash/redis": "^1.37.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "music-metadata": "^11.12.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^9.0.4"
  }
}
